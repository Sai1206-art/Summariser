# ---- Script generation (strongly recommended) ----------------------------
# Claude API key for original script/idea/metadata generation.
# Without it the pipeline runs in "demo mode" (template scripts) which is fine
# for testing but should NOT be published — YouTube's inauthentic-content
# policy penalises mass-produced templated videos.
ANTHROPIC_API_KEY=

# Model used for writing (default: claude-opus-4-8)
AUTOTUBE_MODEL=claude-opus-4-8

# ---- Stock footage (free keys) --------------------------------------------
# https://www.pexels.com/api/  (free, generous limits)
PEXELS_API_KEY=
# https://pixabay.com/api/docs/ (free, fallback source)
PIXABAY_API_KEY=

# ---- Voiceover -------------------------------------------------------------
# edge-tts is free and needs no key. Optionally use ElevenLabs for premium voices:
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ---- YouTube upload ---------------------------------------------------------
# Path to the OAuth client secrets JSON downloaded from Google Cloud Console
# (APIs & Services -> Credentials -> OAuth client ID -> Desktop app).
YOUTUBE_CLIENT_SECRETS=./client_secret.json
# Token file created by `python run.py auth` (do not commit)
YOUTUBE_TOKEN_FILE=./state/youtube_token.json
